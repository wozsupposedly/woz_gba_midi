/*
  GBA_Midi_RP2040_Woz.ino

  Goal: Stable RP2040-first multiboot uploader for a GBA MIDI ROM,
  then USB/DIN MIDI forwarding after the GBA runtime is loaded.

  Attribution:
  - Based on and adapted from the SpritesMods GBA MIDI project by
    Jeroen Domburg / Sprite_tm.
  - Original article: https://spritesmods.com/?art=gbamidi

  License:
  - This adaptation is released under Creative Commons Attribution 2.0
    Generic (CC-BY-2.0). See LICENSE.md.

  Key design choices:
  - Direct GPIO register operations for deterministic edge timing.
  - Cycle-based waits (busy_wait_at_least_cycles) instead of microsecond timers.
  - Same tx/rx bit ordering and handshake flow as original gbaserial.c.
  - Embedded stage1 loader and stage2 gbamidi.gba payload in flash.
  - Stage1 follows tangrs/usb-gba-multiboot's second-stage loader protocol:
    BIOS multiboot first, then SIO normal-mode 32-bit stage2 transfer.
  - USB MIDI and DIN MIDI stay idle until the ROM upload reports success.

 *   RP2040 / Arduino-Pico pin settings:                                   *
 *     - USB MIDI host D+ to 22ohm resistor to GPIO pin 14                 *
 *     - USB MIDI host D- to 22ohm resistor to GPIO pin 15                 * 
 *     - USB MIDI host port requires 5V VBUS power, and two 15k resistors  *
 *     one from D+ to ground, and another from D- to ground.               * 
 *                                                                         *
 *     -IMPORTANT set CPU Speed: "240 MHz (Overclock)"                     *
 *     -NOTE use a ground wire to the usb host thicker than 30awg.         *
 *     -Twist D+ and D-, try to keep them short.                           *
 *     -The 22ohm resistors go near the RP2040.                            *
 *                                                                         *
 *   RP2040 built-in USB works as a USB MIDI device.                       *
 *   RP2040 GPIO14/GPIO15 port works as a USB MIDI host.                   *

  Profile A: GBC / GBAMIDI2 two-stage
  - SC -> GPIO2
  - SI -> GPIO3
  - SD -> GPIO5
  - SO -> GPIO4

  Profile B: GBA (deprecated for GBAMIDI2 stage2 for now)
  - SC -> GPIO2
  - SI -> GPIO3
  - SD -> GPIO5

  - G -> Ground

 3 4
 5 G
 G 2
<--socket, port left (pins toward you)

*/

#include <Arduino.h>
#include <Adafruit_TinyUSB.h>
#include <hardware/gpio.h>
#include <hardware/structs/sio.h>
#include <pico/platform.h>
#include <pico/time.h>

// ---------------- RP2040 pin map (change if needed) ----------------
// GBA signal names are from the GBA side.
constexpr uint8_t PIN_GBA_SC_FIXED = 2;       // GBA SC
constexpr uint8_t PIN_GBA_SI_FIXED = 3;       // GBA SI
constexpr uint8_t PIN_GBA_SO_FIXED = 4;       // GBA SO
constexpr uint8_t PIN_GBA_SD_ALT_STAGE1 = 4;  // Working BIOS multiboot SD path.

constexpr uint8_t PIN_STATUS_LED = 25;  // RP2040 Pico-style onboard LED GPIO

// DIN MIDI is optional. Waveshare RP2040 Zero Serial1 defaults are GPIO0 TX / GPIO1 RX.
constexpr uint8_t PIN_DIN_MIDI_TX = 0;
constexpr uint8_t PIN_DIN_MIDI_RX = 1;
constexpr uint32_t DIN_MIDI_BAUD = 31250;

// ---------------- Upload behavior ----------------
constexpr uint32_t MULTIBOOT_RETRY_MS = 1000;
constexpr uint32_t GBA_WORD_TIMEOUT_US = 20000;
constexpr bool STAGE1_EXEC_DIAGNOSTIC_ONLY = false;
constexpr bool STOP_AFTER_STAGE2_FAILURE = true;

// ---------------- MIDI behavior ----------------
constexpr bool USB_TO_DIN_THRU = true;
constexpr bool DIN_TO_USB_THRU = true;

// Original AVR used (F_CPU / 115200) - 16 because its GPIO/timer code had
// measured AVR-specific overhead. RP2040 direct GPIO uses an accurate cycle
// wait, so do not carry that AVR trim over.
constexpr uint32_t GBA_CHAR_CYCLES = F_CPU / 115200UL;
constexpr uint32_t GBA_NORMAL_MODE_CYCLES = F_CPU / 256000UL;
constexpr uint32_t GBA_NORMAL_MODE_CYCLE_OPTIONS[] = {
  F_CPU / 256000UL,
  F_CPU / 128000UL,
  F_CPU / 64000UL,
  F_CPU / 32000UL,
};
constexpr uint8_t GBA_NORMAL_MODE_CYCLE_OPTION_COUNT = sizeof(GBA_NORMAL_MODE_CYCLE_OPTIONS) / sizeof(GBA_NORMAL_MODE_CYCLE_OPTIONS[0]);
constexpr bool GBA_STAGE2_TIMING_DIAGNOSTIC = false;
constexpr uint8_t GBA_STAGE2_CYCLE_OPTION = 1;  // 128 kHz identified by yellow timing diagnostic.

